{
  "name": "digit",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "npm run build-web && npm run build-cli",
    "build-web": "cd web && pnpm install && pnpm run build",
    "build-cli": "go build .",
    "dev": "cd web && pnpm run dev",
    "clean": "node -e \"require('fs').rmSync('digit',{force:true});require('fs').rmSync('digit.exe',{force:true})\""
  }
}
